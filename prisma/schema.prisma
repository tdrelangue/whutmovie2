// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Movie {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?  // Official IMDb-style synopsis (optional)
  whutSummary String   // Our funny/blunt summary (required)
  year        Int?
  tmdbId      Int?     // TMDB movie ID — cached by sync script, can be set manually in admin
  posterUrl   String?  // TMDB poster image URL (w500), populated by sync script
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // many-to-many implicit
  genres Genre[]

  // ranked picks per category via join model
  categories CategoryAssignment[]

  // streaming availability links
  streamingLinks StreamingLink[]

  // movie group memberships
  groupMemberships MovieGroupMember[]
}

model Genre {
  id   String  @id @default(cuid())
  name String  @unique
  slug String  @unique

  // inverse side of many-to-many
  movies Movie[]
}

model Category {
  id          String               @id @default(cuid())
  title       String               @unique
  slug        String               @unique
  description String               // The "over-explained" humorous category text
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  assignments    CategoryAssignment[]
  groupAssignments CategoryGroupAssignment[]
}

model CategoryAssignment {
  movieId    String
  categoryId String
  rank       Int?
  isHonorableMention Boolean @default(false)

  angleLabel String? // NEW: “Action”, “Rom-com”, “Wildcard”, etc. (per category)

  movie    Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([movieId, categoryId])
  @@unique([categoryId, rank])
}


model StreamingLink {
  id        String   @id @default(cuid())
  movieId   String
  platform  String   // e.g. "NETFLIX", "CANAL_PLUS" — validated by app layer
  region    String   // "FR", "INTL", "BE"
  url       String   // full https:// URL to the watch page
  source    String   @default("MANUAL") // "MANUAL" | "TMDB" — sync script only touches "TMDB" rows
  createdAt DateTime @default(now())

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@index([movieId])
}

model MovieGroup {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members        MovieGroupMember[]
  categoryGroups CategoryGroupAssignment[]
}

model MovieGroupMember {
  id            String  @id @default(cuid())
  groupId       String
  movieId       String
  order         Int     @default(0)
  spoilerHidden Boolean @default(false)

  group MovieGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  movie Movie      @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([groupId, movieId])
  @@index([groupId])
}

model CategoryGroupAssignment {
  id         String @id @default(cuid())
  categoryId String
  groupId    String

  category Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  group    MovieGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([categoryId, groupId])
  @@index([categoryId])
}

model AdminUser {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}
